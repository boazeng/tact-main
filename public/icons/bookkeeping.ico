<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" width="64" height="64">
  <defs>
    <linearGradient id="bg" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0" stop-color="#1e40af"/>
      <stop offset="1" stop-color="#2563eb"/>
    </linearGradient>
  </defs>
  <rect x="2" y="2" width="60" height="60" rx="13" fill="url(#bg)"/>
  <!-- invoice sheet with folded corner -->
  <path d="M18 12 h20 l8 8 v32 a0 0 0 0 1 0 0 H18 a0 0 0 0 1 0 0 Z"
        fill="#ffffff"/>
  <path d="M38 12 v8 h8 Z" fill="#cdddf3"/>
  <!-- text lines -->
  <rect x="23" y="27" width="18" height="3" rx="1.5" fill="#4a5f78"/>
  <rect x="23" y="34" width="18" height="3" rx="1.5" fill="#8899aa"/>
  <!-- total / amount line -->
  <rect x="23" y="43" width="12" height="4" rx="2" fill="#2563eb"/>
  <!-- check / paid mark -->
  <circle cx="42" cy="45" r="6" fill="#16a34a"/>
  <path d="M39 45 l2.2 2.2 L45 43.4" fill="none" stroke="#ffffff"
        stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
</svg>
