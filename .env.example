# TACT portal — secrets. Copy to .env on the box (chmod 600). NEVER commit .env.

# Google OAuth client (Google Cloud Console → Credentials).
# Add this redirect URI to the client: https://tact-main.newavera.co.il/auth/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Random secret for signing session cookies.  Generate with: openssl rand -hex 32
AUTH_SESSION_SECRET=

# Optional emergency login bypass:  /emergency-login?token=<this>
AUTH_EMERGENCY_TOKEN=

# Always-admin email (cannot be locked out)
AUTH_SUPER_ADMIN_EMAIL=boazen@gmail.com

# OAuth redirect — must match the Google console entry and the public URL
AUTH_REDIRECT_URI=https://tact-main.newavera.co.il/auth/callback
